# Obsidian Vault 路径（build-graph.mjs 使用）
VAULT_PATH=C:\Users\Yhx06\Documents\Obsidian Vault

# 发布管理控制台（publish-admin.mjs 使用）
PUBLISH_ADMIN_PORT=4177
# 绑定地址（默认 127.0.0.1，仅本机可访问）
# PUBLISH_ADMIN_HOST=127.0.0.1
# 可选：设置鉴权 token，设置后所有 API 需携带 Authorization: Bearer <token>
# PUBLISH_ADMIN_TOKEN=your-secret-token-here

# 联络页 Discord Webhook 接收地址（需以 REACT_APP_ 开头以暴露给 React 前端）
# REACT_APP_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
